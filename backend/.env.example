# ===== ความปลอดภัย (ต้องเปลี่ยนก่อนใช้งานจริง!) =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=เปลี่ยนรหัสผ่านนี้ให้คาดเดายาก
JWT_SECRET=ใส่ค่าสุ่มยาวๆ-อย่างน้อย-32-ตัวอักษร

# ===== โดเมน frontend ที่อนุญาตให้เรียก API (คั่นหลายอันด้วย ,) =====
CORS_ORIGIN=https://your-frontend.vercel.app

# ===== ฐานข้อมูล: Turso (libSQL) — ฟรี ไม่ต้องมีดิสก์ =====
# สมัครที่ https://turso.tech → สร้าง database → เอา URL + Token มาใส่
# ถ้าไม่ตั้ง (local dev) จะใช้ไฟล์ local.db ในเครื่องอัตโนมัติ
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ===== เก็บรูปอัปโหลด: Cloudinary — ฟรี =====
# สมัครที่ https://cloudinary.com → คัดลอกค่า CLOUDINARY_URL จากหน้า Dashboard
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ===== อีเมลแจ้งเตือนเมื่อมีลูกค้าส่งข้อความ (ทางเลือก) =====
# ถ้าไม่ตั้ง 3 ค่าแรก (HOST/USER/PASS) ระบบจะข้ามการส่งอีเมล — ข้อความยังถูกบันทึกปกติ
# แนะนำใช้ App Password (Gmail) หรือ SMTP ของผู้ให้บริการ transactional
# เช่น Resend / SendGrid / Mailgun — อย่าใช้รหัสผ่านบัญชีจริง
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Gmail: สร้าง App Password ที่ https://myaccount.google.com/apppasswords (ต้องเปิด 2FA ก่อน)
SMTP_PASS=app-password-16-หลัก
# ชื่อ/อีเมลผู้ส่ง (ไม่ตั้งก็ใช้ค่า SMTP_USER)
MAIL_FROM="เว็บไซต์ของฉัน <your-email@gmail.com>"
# อีเมลปลายทางที่จะ "รับ" แจ้งเตือน (ไม่ตั้งจะใช้อีเมลในโปรไฟล์แทน)
NOTIFY_EMAIL=your-email@gmail.com

# PORT มักถูกกำหนดโดยโฮสต์อัตโนมัติ ไม่ต้องตั้งเองก็ได้
# PORT=3000
